@model AgriEcommerce.Models.NguoiDung
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="icon" type="image/png" href="~/Content/images/logocuahang.png" />
    <title>Đăng ký tài khoản</title>
    <!-- Fonts -->
    <link href="~/Content/Admin/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet">
    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- CSS -->
    <link href="~/Content/Admin/css/sb-admin-2.min.css" rel="stylesheet">
</head>
<body class="bg-gradient-primary">
    <div class="container">
        <div class="card o-hidden border-0 shadow-lg my-5">
            <div class="card-body p-0">
                <div class="row">
                    <div class="col-lg-5 d-none d-lg-block bg-register-image"></div>
                    <div class="col-lg-7">
                        <div class="p-5">
                            <div class="text-center">
                                <h1 class="h4 text-gray-900 mb-4">Đăng ký tài khoản khách hàng!</h1>
                            </div>
                            @using (Html.BeginForm("DangKy", "TaiKhoan", FormMethod.Post, new { @class = "user" }))
                            {
                                @Html.AntiForgeryToken()

                                <div class="form-group">
                                    @Html.TextBoxFor(m => m.HoTen, new { @class = "form-control form-control-user", placeholder = "Họ và tên", style = "color:black", required = "required" })
                                </div>

                                <div class="form-group">
                                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control form-control-user", placeholder = "Email", type = "email", style = "color:black", required = "required" })
                                </div>

                                <div class="form-group">
                                    @Html.TextBoxFor(m => m.DienThoai, new { @class = "form-control form-control-user", placeholder = "Số điện thoại", style = "color:black", required = "required" })
                                </div>

                                <div class="form-group">
                                    @Html.TextBoxFor(m => m.DiaChi, new { @class = "form-control form-control-user", placeholder = "Địa chỉ", style = "color:black", required = "required" })
                                </div>

                                <div class="form-group row">
                                    <div class="col-sm-6 mb-3 mb-sm-0">
                                        @Html.PasswordFor(m => m.MatKhau, new { @class = "form-control form-control-user", placeholder = "Mật khẩu", style = "color:black", required = "required" })
                                    </div>
                                    <div class="col-sm-6">
                                        <input type="password"
                                               name="NhapLaiMatKhau"
                                               class="form-control form-control-user"
                                               placeholder="Nhập lại mật khẩu"
                                               style="color:black"
                                               required>
                                    </div>
                                </div>
                                if (ViewBag.ThongBao != null)
                                {
                                    <div class="text-danger small mb-2" style="margin-left:20px;">
                                        @ViewBag.ThongBao
                                    </div>
                                }
                                <button type="submit" class="btn btn-primary btn-user btn-block">
                                    Đăng ký tài khoản
                                </button>
                            }
                            <hr>
                            <div class="text-center">
                                <a class="small" href="/TaiKhoan/QuenMatKhau/">Quên mật khẩu?</a>
                            </div>
                            <div class="text-center">
                                <a class="small" href="/TaiKhoan/DangNhap/">Bạn đã có tài khoản? Đăng nhập!</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- JS -->
    <script src="~/Content/Admin/vendor/jquery/jquery.min.js"></script>
    <script src="~/Content/Admin/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/Content/Admin/vendor/jquery-easing/jquery.easing.min.js"></script>
    <script src="~/Content/Admin/js/sb-admin-2.min.js"></script>
</body>
</html>