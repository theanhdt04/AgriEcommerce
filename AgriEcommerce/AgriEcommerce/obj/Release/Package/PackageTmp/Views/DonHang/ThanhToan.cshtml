@model List<AgriEcommerce.Models.GioHangChiTiet>

@{
    ViewBag.Title = "ThanhToan";
    Layout = "~/Views/Shared/_LayoutCuaHang.cshtml";
    decimal tongTien = 0;
}

@section breadTitle
{
    <li class="breadcrumb-item active text-white">Thanh toán</li>
}

<div class="container-fluid py-5">
    <div class="container py-5">
        <h1 class="mb-4">Thông tin thanh toán</h1>

        @using (Html.BeginForm("DatHang", "DonHang", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="row g-5">

                <!-- ================= THÔNG TIN GIAO HÀNG ================= -->
                <div class="col-md-12 col-lg-6 col-xl-7">

                    <!-- HỌ VÀ TÊN -->
                    <div class="form-item w-100">
                        <label class="form-label my-3">Họ và tên *</label>
                        <input type="text" name="HoTen" class="form-control" required>
                    </div>

                    <!-- SỐ ĐIỆN THOẠI -->
                    <div class="form-item">
                        <label class="form-label my-3">Số điện thoại *</label>
                        <input type="tel" name="DienThoai" class="form-control" required>
                    </div>

                    <!-- ĐỊA CHỈ -->
                    <div class="form-item">
                        <label class="form-label my-3">Địa chỉ giao hàng *</label>
                        <input type="text" name="diaChi" class="form-control" placeholder="Số nhà - Đường - Phường/Xã - Quận/Huyện - Tỉnh/Thành phố" required>
                    </div>

                    <!-- GHI CHÚ -->
                    <div class="form-item">
                        <label class="form-label my-3">Ghi chú</label>
                        <textarea name="ghiChu"
                                  class="form-control"
                                  cols="30"
                                  rows="6"
                                  placeholder="Ghi chú đơn hàng (không bắt buộc)"></textarea>
                    </div>

                </div>

                <!-- ================= DANH SÁCH SẢN PHẨM ================= -->
                <div class="col-md-12 col-lg-6 col-xl-5">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Tên</th>
                                    <th>Giá</th>
                                    <th>Số lượng</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>

                                @foreach (var item in Model)
                                {
                                    decimal gia = item.SanPham.Gia ?? 0;
                                    int sl = item.SoLuong ?? 0;
                                    decimal thanhTien = gia * sl;
                                    tongTien += thanhTien;

                                    <tr>
                                        <th>
                                            <div class="d-flex align-items-center mt-2">
                                                <img src="~/Content/images/@item.SanPham.HinhAnh"
                                                     class="img-fluid rounded-circle"
                                                     style="width: 90px; height: 90px;" />
                                            </div>
                                        </th>
                                        <td class="py-5">@item.SanPham.TenSanPham</td>
                                        <td class="py-5">@gia.ToString("N0") đ</td>
                                        <td class="py-5">@sl</td>
                                        <td class="py-5">@thanhTien.ToString("N0") đ</td>
                                    </tr>
                                }

                                <tr>
                                    <td colspan="4" class="text-end">
                                        <p class="mb-0 text-dark py-3"><strong>Tổng tiền</strong></p>
                                    </td>
                                    <td>
                                        <div class="py-3 border-bottom border-top">
                                            <p class="mb-0 text-dark">
                                                <strong>@tongTien.ToString("N0") đ</strong>
                                            </p>
                                        </div>
                                    </td>
                                </tr>

                            </tbody>
                        </table>
                    </div>

                    <!-- ================= PHƯƠNG THỨC THANH TOÁN ================= -->

                    <div class="form-check text-start my-3">
                        <input type="radio" class="form-check-input bg-primary border-0"
                               name="PaymentMethod" value="BankTransfer" checked>
                        <label class="form-check-label">Chuyển khoản ngân hàng</label>
                    </div>

                    <p class="text-start text-dark">
                        Vui lòng chuyển khoản theo mã đơn hàng. Đơn hàng sẽ được xử lý sau khi nhận được thanh toán.
                    </p>

                    <div class="form-check text-start my-3">
                        <input type="radio" class="form-check-input bg-primary border-0"
                               name="PaymentMethod" value="COD">
                        <label class="form-check-label">Thanh toán khi nhận hàng (COD)</label>
                    </div>

                    <div class="form-check text-start my-3">
                        <input type="radio" class="form-check-input bg-primary border-0"
                               name="PaymentMethod" value="Paypal">
                        <label class="form-check-label">Thanh toán qua Paypal</label>
                    </div>

                    <div class="row g-4 text-center align-items-center justify-content-center pt-4">
                        <button type="submit"
                                class="btn border-secondary py-3 px-4 text-uppercase w-100 text-primary">
                            Đặt hàng
                        </button>
                    </div>

                </div>
            </div>
        }
    </div>
</div>