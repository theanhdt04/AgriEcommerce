@model AgriEcommerce.Models.NguoiDung

@{
    ViewBag.Title = "Thông tin tài khoản";
    Layout = "~/Views/Shared/_LayoutCuaHang.cshtml";
}

<div class="container py-5">
    <div class="row">

        <!-- CỘT TRÁI: HIỂN THỊ THÔNG TIN -->
        <div class="col-md-6">
            <h3>Thông tin tài khoản</h3>

            <table class="table table-bordered">
                <tr>
                    <td><b>Họ tên</b></td>
                    <td>@Model.HoTen</td>
                </tr>
                <tr>
                    <td><b>Email</b></td>
                    <td>@Model.Email</td>
                </tr>
                <tr>
                    <td><b>Số điện thoại</b></td>
                    <td>@Model.DienThoai</td>
                </tr>
                <tr>
                    <td><b>Địa chỉ</b></td>
                    <td>@Model.DiaChi</td>
                </tr>
            </table>
        </div>

        <!-- CỘT PHẢI: SỬA THÔNG TIN -->
        <div class="col-md-6">
            <h3>Thay đổi thông tin</h3>

            @using (Html.BeginForm("SuaThongTin", "TaiKhoan", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                @Html.HiddenFor(m => m.MaNguoiDung)

                <div class="form-group mb-3">
                    <label>Họ tên</label>
                    @Html.TextBoxFor(m => m.HoTen, new { @class = "form-control" })
                </div>

                <div class="form-group mb-3">
                    <label>Email</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", @readonly = "readonly" })
                </div>

                <div class="form-group mb-3">
                    <label>Số điện thoại</label>
                    @Html.TextBoxFor(m => m.DienThoai, new { @class = "form-control" })
                </div>

                <div class="form-group mb-3">
                    <label>Địa chỉ</label>
                    @Html.TextBoxFor(m => m.DiaChi, new { @class = "form-control" })
                </div>

                <button type="submit" class="btn btn-primary">
                    Cập nhật thông tin
                </button>
            }
        </div>

    </div>
</div>