@{
    var user = Session["UserOnline"] as AgriEcommerce.Models.NguoiDung;
}

<div class="container-fluid fixed-top">
    <div class="container topbar bg-primary d-none d-lg-block">
        <div class="d-flex justify-content-between">
            <div class="top-info ps-2">
                <small class="me-3">
                    <i class="fas fa-map-marker-alt me-2 text-secondary"></i>
                    <a href="#" class="text-white">123 Cầu Giấy, Hà Nội</a>
                </small>

                <small class="me-3">
                    <i class="fas fa-envelope me-2 text-secondary"></i>
                    <a href="#" class="text-white">theanh2004@gmail.com</a>
                </small>
            </div>

            <div class="top-link pe-2">
                <a href="#" class="text-white">
                    <small class="text-white mx-2">Chính sách bảo mật</small> /
                </a>

                <a href="#" class="text-white">
                    <small class="text-white mx-2">Điều khoản sử dụng</small> /
                </a>

                <a href="#" class="text-white">
                    <small class="text-white ms-2">Hoàn tiền và đổi trả</small>
                </a>
            </div>
        </div>
    </div>

    <div class="container px-0">
        <nav class="navbar navbar-light bg-white navbar-expand-xl">

            <a href="/TrangChu/danhsach/" class="navbar-brand">
                <h1 class="text-primary display-6">Nông sản sạch</h1>
            </a>

            <button class="navbar-toggler py-2 px-3"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarCollapse">
                <span class="fa fa-bars text-primary"></span>
            </button>

            <div class="collapse navbar-collapse bg-white" id="navbarCollapse">

                <div class="navbar-nav mx-auto">

                    <a href="/TrangChu/danhsach/" class="nav-item nav-link">
                        Trang chủ
                    </a>

                    <a href="/CuaHang/danhsach/" class="nav-item nav-link">
                        Cửa hàng
                    </a>

                    <a href="/GioHang/danhsach/" class="nav-item nav-link">
                        Giỏ hàng
                    </a>

                    <a href="/DonHang/LichSuDonHang/" class="nav-item nav-link">
                        Đơn hàng
                    </a>

                    @* Chỉ Admin thấy *@
                    @if (user != null && user.MaVaiTro == "VT01")
                    {
                        <a href="/SanPham/danhsach/" class="nav-item nav-link">
                            Quản lý cửa hàng
                        </a>
                    }

                    <a href="/TrangChu/LienHe/" class="nav-item nav-link">
                        Liên hệ
                    </a>

                </div>

                <div class="d-flex m-3 me-0">

                    <button class="btn-search btn border border-secondary btn-md-square rounded-circle bg-white me-4"
                            data-bs-toggle="modal"
                            data-bs-target="#searchModal">
                        <i class="fas fa-search text-primary"></i>
                    </button>

                    <a href="/GioHang/danhsach/" class="position-relative me-4 my-auto">
                        <i class="fa fa-shopping-bag fa-2x"></i>
                    </a>

                    <div class="dropdown my-auto">

                        <a class="dropdown-toggle"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown">
                            <i class="fas fa-user fa-2x"></i>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end">

                            @* Chưa đăng nhập *@
                            @if (user == null)
                            {
                                <li>
                                    <a class="dropdown-item"
                                       href="@Url.Action("DangNhap","TaiKhoan")">
                                        Đăng nhập
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       href="@Url.Action("DangKy","TaiKhoan")">
                                        Đăng ký
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li>
                                    <span class="dropdown-item-text" style="white-space:nowrap;">
                                        Xin chào: <b>@user.HoTen</b>
                                    </span>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       href="@Url.Action("ThongTin","TaiKhoan")">
                                        Thông tin tài khoản
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       href="@Url.Action("LichSuDonHang","DonHang")">
                                        Đơn hàng của tôi
                                    </a>
                                </li>

                                @* Admin *@
                                if (user.MaVaiTro == "VT01")
                                {
                                    <li>
                                        <a class="dropdown-item"
                                           href="/SanPham/danhsach">
                                            Quản trị hệ thống
                                        </a>
                                    </li>
                                }

                                <li>
                                    <a class="dropdown-item"
                                       href="@Url.Action("DangXuat","TaiKhoan")">
                                        Đăng xuất
                                    </a>
                                </li>
                            }

                        </ul>
                    </div>

                </div>

            </div>

        </nav>
    </div>
</div>