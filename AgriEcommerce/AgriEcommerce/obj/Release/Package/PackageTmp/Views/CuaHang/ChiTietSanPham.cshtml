@model AgriEcommerce.Models.SanPham

@{
    ViewBag.Title = "ChiTietSanPham";
    Layout = "~/Views/Shared/_LayoutCuaHang.cshtml";
}

@section breadTitle
{
    <li class="breadcrumb-item active text-white">Chi tiết sản phẩm</li>
}

<div class="container py-5">
    <div class="row g-4 mb-5">
        <div class="col-lg-8 col-xl-9">
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="border rounded product-box">
                        <a href="#">
                            <div class="product-img">
                                <img src="~/Content/images/@Model.HinhAnh" alt="Image">
                            </div>
                        </a>
                    </div>
                </div>
                <div class="col-lg-6">
                    <h4 class="fw-bold mb-3">Tên sản phẩm: @Model.TenSanPham</h4>
                    <p class="mb-3">Danh mục sản phẩm: @Model.DanhMuc.TenDanhMuc</p>
                    <h5 class="fw-bold mb-3 text-danger">Giá: @String.Format("{0:N0}", Model.Gia) VNĐ</h5>
                    <p class="mb-4">@Model.MoTa</p>
                    <div class="input-group quantity mb-5" style="height: 80px;">
                        
                    </div>
                    <div class="d-flex gap-3 mt-3">
                        <a href="@Url.Action("ThemGioHang","GioHang", new { id = Model.MaSanPham })"
                           class="btn border border-secondary rounded-pill text-primary btn-equal">
                            <i class="fa fa-shopping-bag me-2 text-primary"></i> Đưa vào giỏ
                        </a>

                        <a href="/CuaHang/danhsach/"
                           class="btn border border-secondary rounded-pill text-primary btn-equal">
                            <i class="fa fa-undo me-2 text-primary"></i> Trở lại cửa hàng
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .product-box {
        border: 1px solid #ddd;
        border-radius: 12px;
        padding: 10px;
        background: #fff;
        box-shadow: 0 3px 10px rgba(0,0,0,0.08);
    }
    .product-img {
        width: 350px;
        height: 350px;
        overflow: hidden;
        margin: auto;
    }
    .product-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 10px;
    }
    .btn-equal {
        width: 200px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
